{
  "name": "@lobu/client",
  "version": "13.2.0",
  "description": "TypeScript client for the Lobu Agent API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "clean": "rm -rf dist",
    "generate": "openapi-ts"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/lobu-ai/lobu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/client"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.86.5",
    "typescript": "^5.8.3"
  }
}
