---
import { getCollection } from "astro:content";
import { Footer } from "../../components/Footer";
import { Nav } from "../../components/Nav";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../globals.css";

const isProduction = import.meta.env.PROD;

const posts = (
  await getCollection("blog", ({ data }) => (isProduction ? !data.draft : true))
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog - Lobu" description="Updates and insights from the Lobu team.">
  <div class="min-h-screen grid-lines" style={{ backgroundColor: "var(--color-page-bg)" }}>
    <Nav client:load currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <div class="pt-28 pb-8 px-6">
        <div class="max-w-5xl mx-auto">
          <h1
            class="text-4xl sm:text-5xl font-bold tracking-tight"
            style={{ color: "var(--color-page-text)" }}
          >
            Blog
          </h1>
        </div>
      </div>

      <div class="section-divider" />

      <div class="max-w-5xl mx-auto px-6 py-12">
        {posts.length === 0 && (
          <p style={{ color: "var(--color-page-text-muted)" }}>No posts yet. Check back soon.</p>
        )}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style={{ backgroundColor: "var(--color-page-border)" }}>
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col justify-between p-6 transition-colors"
              style={{ backgroundColor: "var(--color-page-bg)" }}
            >
              <div>
                {/* Date */}
                <div class="flex items-center justify-between mb-8">
                  {post.data.tags.length > 0 && (
                    <span
                      class="text-[10px] font-medium px-2 py-0.5 rounded-full"
                      style={{
                        backgroundColor: "var(--color-page-surface-dim)",
                        color: "var(--color-page-text-muted)",
                        border: "1px solid var(--color-page-border)",
                      }}
                    >
                      {post.data.tags[0]}
                    </span>
                  )}
                  <time
                    class="text-sm"
                    style={{ color: "var(--color-page-text-muted)" }}
                  >
                    {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </time>
                </div>

                {/* Title */}
                <h2
                  class="text-xl sm:text-2xl font-bold leading-tight mb-4 transition-colors group-hover:opacity-80"
                  style={{ color: "var(--color-page-text)" }}
                >
                  {post.data.title}
                </h2>

                {/* Description */}
                <p
                  class="text-sm leading-relaxed line-clamp-4 mb-8"
                  style={{ color: "var(--color-page-text-muted)" }}
                >
                  {post.data.description}
                </p>
              </div>

              {/* Author */}
              <div class="flex items-center gap-2.5 mt-auto">
                {post.data.authorAvatar && (
                  <img
                    src={post.data.authorAvatar}
                    alt={post.data.author}
                    class="w-6 h-6 rounded-full"
                    loading="lazy"
                  />
                )}
                <span
                  class="text-sm"
                  style={{ color: "var(--color-page-text-muted)" }}
                >
                  {post.data.author}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
