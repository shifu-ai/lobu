---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../globals.css";
import { Footer } from "../../components/Footer";
import { LandingPage } from "../../components/LandingPage";
import { Nav } from "../../components/Nav";
import {
  getLandingUseCaseShowcase,
  getSurfaceHeroCopy,
  landingUseCaseRouteEntries,
} from "../../use-case-showcases";
import { getLatestPosts } from "../../latest-posts";

export function getStaticPaths() {
  return landingUseCaseRouteEntries.map((entry) => ({
    params: { useCase: entry.routeId },
    props: { useCaseId: entry.useCaseId },
  }));
}

const { useCaseId } = Astro.props;
const showcase = getLandingUseCaseShowcase(useCaseId);
const latestPosts = await getLatestPosts(3);
---

<BaseLayout
  title={showcase.campaign.seoTitle}
  description={showcase.campaign.seoDescription}
>
  <div
    class="min-h-screen grid-lines overflow-x-hidden"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <LandingPage
        client:load
        defaultUseCaseId={showcase.id}
        linkTabsToCampaigns
        heroCopy={getSurfaceHeroCopy("landing", showcase.id)}
        latestPosts={latestPosts}
      />
    </main>
    <Footer />
  </div>
</BaseLayout>
