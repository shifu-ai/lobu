---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { Nav } from "../components/Nav";
import { ServerlessSection } from "../components/ServerlessSection";
---

<BaseLayout title="Serverless OpenClaw - Lobu" description="Serverless OpenClaw agents with pay-per-use billing. Agents sleep when idle — you only pay for active CPU and memory.">
  <div class="min-h-screen grid-lines" style={{ backgroundColor: "var(--color-page-bg)" }}>
    <Nav client:load currentPath={Astro.url.pathname} />
    <main class="relative z-[1]">
      <ServerlessSection client:load />
    </main>
    <Footer />
  </div>
</BaseLayout>
