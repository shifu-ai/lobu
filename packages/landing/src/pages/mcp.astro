---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { Nav } from "../components/Nav";

const mcpUrl = "https://app.lobu.ai/mcp";
const claudeCodeCommand = `claude mcp add --transport http lobu ${mcpUrl}`;
const openClawCommand = `lobu memory configure --url ${mcpUrl} --org <org-slug>`;

const clients = [
  {
    name: "Claude (web + desktop)",
    href: "/connect-from/claude/",
    body: "Settings → Connectors → Add Custom Connector. Paste the URL, sign in with Lobu.",
  },
  {
    name: "ChatGPT",
    href: "/connect-from/chatgpt/",
    body: "Settings → Integrations → Model Context Protocol → Add Server. Paste the URL.",
  },
  {
    name: "Claude Code",
    href: "/connect-from/claude/",
    body: claudeCodeCommand,
    mono: true,
  },
  {
    name: "OpenClaw",
    href: "/connect-from/openclaw/",
    body: openClawCommand,
    mono: true,
  },
];
---

<BaseLayout
  title="Lobu MCP - Connect agents to your multi-user backend"
  description="https://app.lobu.ai/mcp is the canonical MCP endpoint. Sign in once, then use org-scoped memory, connectors, watchers, and tools from any MCP-capable agent."
>
  <div
    class="min-h-screen grid-lines"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav client:load currentPath={Astro.url.pathname} />
    <main class="relative z-[1] pt-32 pb-24 px-6">
      <div class="max-w-[40rem] mx-auto">
        <p
          class="text-xs uppercase tracking-[0.2em] mb-4"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          MCP endpoint
        </p>
        <h1
          class="text-4xl sm:text-5xl font-bold tracking-tight mb-6"
          style={{ color: "var(--color-page-text)" }}
        >
          Connect agents to your Lobu backend
        </h1>
        <p
          class="text-lg leading-relaxed mb-8"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          Paste this Streamable HTTP MCP URL into any compatible client. After
          OAuth, agents can use org-scoped memory, connectors, watchers, and
          tools without seeing raw credentials.
        </p>

        <div
          class="rounded-lg p-4 mb-10 font-mono text-sm break-all"
          style={{
            backgroundColor: "var(--color-page-surface)",
            border: "1px solid var(--color-page-border)",
            color: "var(--color-page-text)",
          }}
        >
          {mcpUrl}
        </div>

        <h2
          class="text-xl font-semibold mb-4"
          style={{ color: "var(--color-page-text)" }}
        >
          Per-client setup
        </h2>
        <ul class="space-y-4 mb-12">
          {clients.map((client) => (
            <li
              class="rounded-lg p-4"
              style={{
                backgroundColor: "var(--color-page-surface)",
                border: "1px solid var(--color-page-border)",
              }}
            >
              <a
                href={client.href}
                class="font-semibold text-base hover:opacity-80 transition-opacity"
                style={{ color: "var(--color-page-text)" }}
              >
                {client.name} →
              </a>
              <p
                class={`mt-2 text-sm ${client.mono ? "font-mono break-all" : ""}`}
                style={{ color: "var(--color-page-text-muted)" }}
              >
                {client.body}
              </p>
            </li>
          ))}
        </ul>

        <p
          class="text-xs mb-10 leading-relaxed"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          <strong>Self-hosting note:</strong> If you are self-hosting or running locally, replace <code>https://app.lobu.ai/mcp</code> in the commands/URLs above with your custom instance URL (e.g., <code>http://localhost:8787/mcp</code>).
        </p>

        <h2
          class="text-xl font-semibold mb-4"
          style={{ color: "var(--color-page-text)" }}
        >
          What this endpoint exposes
        </h2>
        <ul
          class="space-y-2 text-sm leading-relaxed list-disc pl-5"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          <li>
            <strong>Cross-org tools.</strong> Until you call
            <code class="font-mono">switch_organization</code>, only org-listing
            and account tools are visible.
          </li>
          <li>
            <strong>Per-org tools, scoped on demand.</strong> After switching,
            the same session sees the workspace's entities, watchers,
            connectors, and memory.
          </li>
          <li>
            <strong>One sign-in per agent.</strong> OAuth is brokered by Lobu;
            tokens never leave the platform.
          </li>
        </ul>

        <p
          class="mt-12 text-sm"
          style={{ color: "var(--color-page-text-muted)" }}
        >
          Want a per-org URL instead?
          <a
            href="https://app.lobu.ai"
            class="underline hover:opacity-80 transition-opacity"
            style={{ color: "var(--color-page-text)" }}
          >
            Sign in
          </a>
          and grab the
          <code class="font-mono text-xs">{`{org}.lobu.ai/mcp`}</code>
          endpoint from your workspace settings.
        </p>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
