---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

// Fetch spec server-side (build time for prod, per-request in dev) — no CORS issues.
// Try the local dev gateway first, then fall back to production so the page
// always renders something useful even when the local gateway is offline.
const specOrigins = import.meta.env.DEV
  ? ["http://localhost:8080", "https://app.lobu.ai"]
  : ["https://app.lobu.ai"];

let spec: string | null = null;
let resolvedOrigin = specOrigins[specOrigins.length - 1];
for (const origin of specOrigins) {
  try {
    const res = await fetch(`${origin}/openapi.json`);
    if (res.ok) {
      const text = await res.text();
      if (text.length > 0) {
        spec = text;
        resolvedOrigin = origin;
        break;
      }
    }
  } catch {
    // try next origin
  }
}

const config = JSON.stringify({
  ...(spec ? { content: spec } : { url: `${resolvedOrigin}/openapi.json` }),
  theme: "default",
  layout: "modern",
  darkMode: false,
  forceDarkModeState: "light",
  defaultHttpClient: { targetKey: "js", clientKey: "fetch" },
  servers: [{ url: resolvedOrigin, description: "Lobu API" }],
});
---

<StarlightPage
  frontmatter={{
    title: "API Reference",
    description: "Interactive API reference for the Lobu gateway REST API.",
    template: "splash",
  }}
  hasSidebar={false}
>
  <div id="scalar-api-reference"></div>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@scalar/api-reference"></script>
  <script is:inline define:vars={{ config }}>
    Scalar.createApiReference("#scalar-api-reference", JSON.parse(config));
  </script>
</StarlightPage>

<style is:global>
  .scalar-app {
    --scalar-color-2: #4b5563;
    --scalar-color-3: #4b5563;
    --scalar-sidebar-color-2: #4b5563;
    --scalar-color-accent: #c2410c;
  }

  /* Let the Scalar component take the full viewport width */
  .main-pane {
    max-width: 100% !important;
  }
  .content-panel {
    max-width: 100% !important;
    padding: 0 !important;
  }
  .sl-container {
    max-width: 100% !important;
  }
  /* Hide the Starlight page title — Scalar has its own header */
  h1#_top {
    display: none !important;
  }
</style>
