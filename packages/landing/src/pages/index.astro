---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../globals.css";
import { Footer } from "../components/Footer";
import { LandingPage } from "../components/LandingPage";
import { Nav } from "../components/Nav";
import { getLatestPosts } from "../latest-posts";

const latestPosts = await getLatestPosts(3);
---

<BaseLayout forceTheme="dark">
  <div
    class="landing-backdrop min-h-screen grid-lines relative"
    style={{
      backgroundColor: "var(--color-page-bg)",
      "--grid-max-w": "72rem",
    }}
  >
    <Nav client:load currentPath={Astro.url.pathname} />
    <main class="relative z-[1] -mt-16">
      <LandingPage client:load latestPosts={latestPosts} />
    </main>
    <Footer />
  </div>
</BaseLayout>

