---
interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  article?: {
    publishedTime: string;
    author: string;
    tags: string[];
  };
}

const {
  title = "Lobu - Deploy autonomous AI agents",
  description = "Open-source platform for persistent, sandboxed AI agents with shared memory, installable skills, chat integrations, and MCP access.",
  ogType = "website",
  article,
} = Astro.props;

import { existsSync } from "node:fs";
import PosthogAnalytics from "../components/PosthogAnalytics.astro";
import WebMCP from "../components/WebMCP.astro";
import { themeScript } from "../styles/theme-script";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/lobster-icon.png", Astro.site);
const markdownPath =
  Astro.url.pathname === "/"
    ? "/index.md"
    : `${Astro.url.pathname.replace(/\/$/, "")}.md`;
const markdownURL = new URL(markdownPath, Astro.site);
const markdownFileURL = new URL(`../../public${markdownPath}`, import.meta.url);
const hasMarkdownTwin = existsSync(markdownFileURL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/lobster-icon.png" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Lobu" />

    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:author" content={article.author} />
        {article.tags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Inter + Inter Display (matches attio.com typography) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Lobu",
      "url": "https://lobu.ai",
      "logo": "https://lobu.ai/lobster-icon.png",
      "description": "Open-source platform for persistent, sandboxed AI agents with shared memory, installable skills, chat integrations, and MCP access.",
      "sameAs": [
        "https://github.com/lobu-ai/lobu",
        "https://x.com/bu7emba"
      ]
    })} />
    <PosthogAnalytics />
    <WebMCP />

    <!-- Agent discovery hints -->
    {hasMarkdownTwin && <link rel="alternate" type="text/markdown" href={markdownURL} />}
    <link rel="describedby" type="text/plain" href="/llms.txt" />
    <link rel="https://modelcontextprotocol.io/rel/server-card" type="application/json" href="/.well-known/mcp/server-card.json" />
    <link rel="api-catalog" href="/.well-known/api-catalog" />
  </head>
  <body>
    <!-- Apply theme tokens via inline styles to defeat Tailwind v4 @layer cascade -->
    <script is:inline set:html={themeScript(Astro)} />
    <slot />
  </body>
</html>
