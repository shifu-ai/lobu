---
interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  article?: {
    publishedTime: string;
    author: string;
    tags: string[];
  };
}

const {
  title = "Lobu - Deploy autonomous AI agents",
  description = "Open-source platform for deploying persistent, sandboxed AI agents on Slack, Telegram, WhatsApp, and REST API.",
  ogType = "website",
  article,
} = Astro.props;

import PosthogAnalytics from "../components/PosthogAnalytics.astro";
import WebMCP from "../components/WebMCP.astro";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/lobster-icon.png", Astro.site);
const markdownPath =
  Astro.url.pathname === "/"
    ? "/index.md"
    : `${Astro.url.pathname.replace(/\/$/, "")}.md`;
const markdownURL = new URL(markdownPath, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/lobster-icon.png" />
    <meta name="theme-color" content="#f7f7f5" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Lobu" />

    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        <meta property="article:author" content={article.author} />
        {article.tags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Inter font -->
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Lobu",
      "url": "https://lobu.ai",
      "logo": "https://lobu.ai/lobster-icon.png",
      "description": "Open-source platform for deploying persistent, sandboxed AI agents on Slack, Telegram, WhatsApp, and REST API.",
      "sameAs": [
        "https://github.com/lobu-ai/lobu",
        "https://x.com/bu7emba"
      ]
    })} />
    <PosthogAnalytics />
    <WebMCP />

    <!-- Agent discovery hints -->
    <link rel="alternate" type="text/markdown" href={markdownURL} />
    <link rel="describedby" type="text/plain" href="/llms.txt" />
    <link rel="https://modelcontextprotocol.io/rel/server-card" type="application/json" href="/.well-known/mcp/server-card.json" />
    <link rel="api-catalog" href="/.well-known/api-catalog" />
  </head>
  <body>
    <slot />
  </body>
</html>
