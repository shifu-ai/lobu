[0.0, "o", "\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[2C\u001b[38;5;39mHaiku\u001b[1C4.5\u001b[38;5;246m \u001b[38;5;216m\ud83e\udde0\u001b[38;5;246m \u001b[2m|\u001b[22m \u001b[38;5;216m60k\u001b[38;5;246m \u001b[38;5;34m30%\u001b[38;5;246m \u001b[2m|\u001b[22m \u001b[38;5;177msupport-bot\u001b[39m\r\r\n\u001b[2C\u001b[38;5;253mcurrent:\u001b[38;5;246m \u001b[38;5;216m58%\u001b[38;5;246m \u001b[2mresets\u001b[1C11:30p.m.\u001b[22m \u001b[2m|\u001b[22m \u001b[38;5;253mweekly:\u001b[38;5;246m \u001b[38;5;210m90%\u001b[38;5;246m \u001b[2mresets\u001b[1Cmay\u001b[1C20,\u001b[1C8:00a.m.\u001b[22m\u001b[39m\r\r\n\u001b[2C\u001b[38;5;211m\u23f5\u23f5\u001b[1Cbypass\u001b[1Cpermissions\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[39m\r\r\n\u001b[86C\u001b[38;5;246m60355\u001b[1Ctokens\u001b[39m\r\r\n\u001b[58C\u001b[38;5;211m1\u001b[1Cclaude.ai\u001b[1Cconnector\u001b[1Cunavailable\u001b[38;5;246m \u00b7\u001b[1C/mcp\u001b[39m\r\r\n\u001b[2C\u001b[7A"]
