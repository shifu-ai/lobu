{
  "name": "@lobu/promptfoo-provider",
  "version": "10.1.0",
  "description": "promptfoo custom provider for running evals against a Lobu agent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/lobu-ai/lobu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/promptfoo-provider"
  }
}
