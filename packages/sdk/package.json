{
  "name": "@lobu/sdk",
  "version": "9.1.1",
  "description": "Lobu authoring SDK — define agents, connectors, watchers, and connections in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lobu/connector-sdk": "workspace:*",
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/lobu-ai/lobu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobu-ai/lobu.git",
    "directory": "packages/sdk"
  }
}
