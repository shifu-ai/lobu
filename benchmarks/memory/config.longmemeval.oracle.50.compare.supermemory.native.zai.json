{
  "suitePath": "benchmarks/memory/suites/longmemeval-oracle.50.json",
  "outputDir": ".lobu/benchmarks/memory/public-compare",
  "trials": 3,
  "topK": 8,
  "answerer": {
    "type": "openai-compatible",
    "model": "glm-5.1",
    "baseUrl": "https://api.z.ai/api/coding/paas/v4/",
    "apiKeyEnv": "ZAI_API_KEY",
    "temperature": 0,
    "maxTokens": 300
  },
  "systems": [
    {
      "id": "lobu-local",
      "label": "Lobu (local in-process)",
      "type": "lobu-inprocess",
      "embedWrites": false,
      "topK": 8,
      "searchLimit": 5,
      "readLimit": 8,
      "linkLimit": 8
    },
    {
      "id": "supermemory",
      "label": "Supermemory",
      "type": "command",
      "argv": ["python3", "benchmarks/memory/adapters/supermemory_adapter.py"],
      "env": {
        "SUPERMEMORY_API_KEY": "$SUPERMEMORY_API_KEY"
      },
      "topK": 8
    },
    {
      "id": "supermemory-rerank",
      "label": "Supermemory (rerank)",
      "type": "command",
      "argv": ["python3", "benchmarks/memory/adapters/supermemory_adapter.py"],
      "env": {
        "SUPERMEMORY_API_KEY": "$SUPERMEMORY_API_KEY",
        "SUPERMEMORY_RERANK": "1",
        "SUPERMEMORY_THRESHOLD": "0.6"
      },
      "topK": 8
    },
    {
      "id": "supermemory-profile",
      "label": "Supermemory (profile+search)",
      "type": "command",
      "argv": ["python3", "benchmarks/memory/adapters/supermemory_adapter.py"],
      "env": {
        "SUPERMEMORY_API_KEY": "$SUPERMEMORY_API_KEY",
        "SUPERMEMORY_USE_PROFILE": "1",
        "SUPERMEMORY_THRESHOLD": "0.6"
      },
      "topK": 8
    }
  ]
}
